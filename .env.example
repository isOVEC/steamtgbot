# Пример конфигурационного файла
# Скопируйте этот файл в .env и заполните своими данными

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID в Telegram (получить у @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# Steam API Key (получить на https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your_steam_api_key_here

# Proxy (опционально)
# PROXY_URL=http://username:password@ip:port

# Интервал проверки инвентаря в минутах (5-1440, по умолчанию 30)
CHECK_INTERVAL_MINUTES=30
